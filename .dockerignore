# Ignore files not needed for docker to build microservice image
node_modules/*
postgres/*
typings/*
*/.git*
*.git*
*.git
*.md
!gulpfile.js
ci/
.circleci/
Vagrantfile
concourse/
infra/*
vagrant/*
docker/Dockerfile
docker/database/
deploy/*
media/*
data/*
appspec.yml
compose.yml
docker-compose-prod.yml
docker-compose.yml
$virtualenv.tar.gz
$node_modules.tar.gz
docker-compose.override.yml
**/node_modules/
**/.git/
# Excluir dist/ en general, EXCEPTO console/dist/ que se usa en modo pre-built.
# El Dockerfile.prebuilt necesita acceso a console/dist/ en el contexto de build.
**/dist/
!console/dist/
**/tmp/
**/.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.development.local
.env.test.local
.env.production.local