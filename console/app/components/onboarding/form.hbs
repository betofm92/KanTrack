<div class="min-h-screen flex items-center justify-center bg-zinc-50 dark:bg-zinc-950">
    <div class="bg-white dark:bg-neutral-800 py-5 px-4 shadow rounded-lg w-full max-w-md">
    <div class="mb-4">
        <Image src="/images/kantrack-logo-png.png" alt={{t "app.name"}} height="106" class="h-26 object-contain mx-auto" />
        <div class="mt-2">
            <h2 class="text-center text-lg font-extrabold text-gray-900 dark:text-neutral-100 truncate">
                {{t "onboard.index.title"}}
            </h2>
        </div>
    </div>

    <div class="flex px-3 py-2 mb-4 rounded-md shadow-sm bg-yellow-100 dark:bg-yellow-900">
        <div>
            <FaIcon @icon="hand-spock" @size="lg" class="text-yellow-700 dark:text-yellow-200 mr-4" />
        </div>
        <p class="flex-1 text-sm text-yellow-900 dark:text-yellow-100">
            {{t "onboard.index.welcome-title" htmlSafe=true companyName=(t "app.name")}}
            {{t "onboard.index.welcome-text"}}
        </p>
    </div>

    <form {{on "submit" (perform this.onboard)}}>
        {{#if this.error}}
            <InfoBlock @icon="exclamation-triangle" @text={{this.error}} class="mb-6 px-3 py-2 bg-red-300 text-red-900 dark:bg-red-900 dark:text-red-100" @textClass="text-red-900 dark:text-red-100" />
        {{/if}}
        <InputGroup @name={{t "onboard.index.full-name"}} @value={{this.name}} @helpText={{t "onboard.index.full-name-help-text"}} @inputClass="input-lg bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />
        <InputGroup @name={{t "onboard.index.your-email"}} @type="email" @value={{this.email}} @helpText={{t "onboard.index.your-email-help-text"}} @inputClass="input-lg bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />
        <InputGroup @name={{t "onboard.index.phone"}} @helpText={{t "onboard.index.phone-help-text"}}>
            <PhoneInput @onInput={{fn (mut this.phone)}} class="form-input input-lg w-full bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />
        </InputGroup>
        <InputGroup @name={{t "onboard.index.organization-name"}} @value={{this.organization_name}} @helpText={{t "onboard.index.organization-help-text"}} @inputClass="input-lg bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />
        <InputGroup @name={{t "onboard.index.password"}} @value={{this.password}} @type="password" @helpText={{t "onboard.index.password-help-text"}} @inputClass="input-lg bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />
        <InputGroup @name={{t "onboard.index.confirm-password"}} @value={{this.password_confirmation}} @type="password" @helpText={{t "onboard.index.confirm-password-help-text"}} @inputClass="input-lg bg-gray-100 dark:bg-neutral-700 dark:text-neutral-100" />

        <div class="flex items-center justify-end mt-5">
            <Button @buttonType="submit" @icon="check" @iconPrefix="fas" @type="primary" @size="lg" @text={{t "onboard.index.continue-button-text"}} @isLoading={{this.onboard.isRunning}} @disabled={{not this.filled}} class="bg-yellow-700 dark:bg-yellow-600 text-white hover:bg-yellow-800 dark:hover:bg-yellow-700" />
        </div>
    </form>

    <RegistryYield @registry="onboard" as |YieldedComponent ctx|>
        <YieldedComponent @context={{ctx}} />
    </RegistryYield>
  </div>
</div>