<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container pt-0i text-gray-900 dark:text-white">
        {{#if @options.isOwner}}
            {{#if @options.hasOtherMembers}}
                <p>
                    <div class="text-base mb-2">
                        {{t "modals.leave-organization.owner-with-members-title" name=@options.organization.name}}
                    </div>
                    <div>{{t "modals.leave-organization.owner-with-members-instructions"}}</div>
                </p>
                <InputGroup @name={{t "modals.leave-organization.select-new-owner-label"}} @wrapperClass="mt-2 mb-0i">
                    <Select
                        @options={{@options.organization.users}}
                        @value={{@options.newOwnerId}}
                        @onSelect={{@options.selectNewOwner}}
                        @optionLabel="name"
                        @optionValue="id"
                        @placeholder={{t "modals.leave-organization.select-member-placeholder"}}
                    />
                </InputGroup>
            {{else if @options.willBeDeleted}}
                <p>
                    <div class="text-base mb-2">
                        {{t "modals.leave-organization.sole-owner-title" name=@options.organization.name}}
                    </div>
                    <div>{{t "modals.leave-organization.sole-owner-warning"}}</div>
                    <div>{{t "modals.leave-organization.sole-owner-confirm"}}</div>
                </p>
                <p class="mt-3"><em>{{t "modals.leave-organization.sole-owner-irreversible"}}</em></p>
            {{/if}}
        {{else}}
            <p>
                <div class="text-base mb-2">
                    {{t "modals.leave-organization.member-title" name=@options.organization.name}}
                </div>
                <div>{{t "modals.leave-organization.member-warning"}}</div>
            </p>
        {{/if}}
    </div>
</Modal::Default>