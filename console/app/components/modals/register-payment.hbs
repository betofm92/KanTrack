<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container pt-0 text-gray-900 dark:text-white">

        {{#if @options.subscription}}
            <div class="mb-4 p-3 rounded-lg bg-gray-100 dark:bg-gray-800 text-sm">
                <p class="font-medium mb-1">{{t "modals.register-payment.current-subscription"}}</p>
                <p>{{t "modals.subscription-history.plan-label"}} <strong>{{@options.subscription.plan_slug}}</strong></p>
                <p>{{t "modals.subscription-history.status-label"}} <strong>{{@options.subscription.status}}</strong></p>
                {{#if @options.subscription.expires_at}}
                    <p>{{t "modals.subscription-history.expiry-label"}} <strong>{{@options.subscription_expires_display}}</strong></p>
                {{/if}}
            </div>
        {{/if}}

        <div class="grid grid-cols-2 gap-4">
            <InputGroup @name={{t "modals.register-payment.amount-label"}} @wrapperClass="col-span-1">
                <Input @type="number" @value={{@options.form.amount}} class="form-input w-full" min="0" step="0.01" placeholder="0.00" />
            </InputGroup>
            <InputGroup @name={{t "modals.register-payment.currency-label"}} @wrapperClass="col-span-1">
                <select class="form-select w-full" onchange={{action (mut @options.form.currency) value="target.value"}}>
                    <option value="USD" selected={{eq @options.form.currency "USD"}}>USD</option>
                    <option value="EUR" selected={{eq @options.form.currency "EUR"}}>EUR</option>
                </select>
            </InputGroup>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <InputGroup @name={{t "modals.register-payment.payment-method-label"}} @wrapperClass="col-span-1">
                <select class="form-select w-full" onchange={{action (mut @options.form.payment_method) value="target.value"}}>
                    <option value="">{{t "modals.register-payment.select-method-placeholder"}}</option>
                    <option value="bank_transfer" selected={{eq @options.form.payment_method "bank_transfer"}}>{{t "modals.register-payment.method-transfer"}}</option>
                    <option value="cash" selected={{eq @options.form.payment_method "cash"}}>{{t "modals.register-payment.method-cash"}}</option>
                    <option value="card" selected={{eq @options.form.payment_method "card"}}>{{t "modals.register-payment.method-card"}}</option>
                    <option value="paypal" selected={{eq @options.form.payment_method "paypal"}}>{{t "modals.register-payment.method-paypal"}}</option>
                    <option value="other" selected={{eq @options.form.payment_method "other"}}>{{t "modals.register-payment.method-other"}}</option>
                </select>
            </InputGroup>
            <InputGroup @name={{t "modals.register-payment.billing-cycle-label"}} @wrapperClass="col-span-1">
                <select class="form-select w-full" onchange={{action (mut @options.form.billing_cycle) value="target.value"}}>
                    <option value="monthly" selected={{eq @options.form.billing_cycle "monthly"}}>{{t "modals.assign-plan.cycle-monthly"}}</option>
                    <option value="annual" selected={{eq @options.form.billing_cycle "annual"}}>{{t "modals.assign-plan.cycle-annual"}}</option>
                    <option value="custom" selected={{eq @options.form.billing_cycle "custom"}}>{{t "modals.assign-plan.cycle-custom"}}</option>
                </select>
            </InputGroup>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <InputGroup @name={{t "modals.register-payment.reference-label"}} @wrapperClass="col-span-1">
                <Input @type="text" @value={{@options.form.reference}} class="form-input w-full" placeholder={{t "modals.register-payment.reference-placeholder"}} />
            </InputGroup>
            <InputGroup @name={{t "modals.register-payment.payment-date-label"}} @wrapperClass="col-span-1">
                <Input @type="date" @value={{@options.form.paid_at}} class="form-input w-full" />
            </InputGroup>
        </div>

        {{#if (eq @options.form.billing_cycle "custom")}}
            <InputGroup @name={{t "modals.register-payment.new-expiry-label"}}>
                <Input @type="date" @value={{@options.form.period_end}} class="form-input w-full" />
            </InputGroup>
        {{/if}}

        <InputGroup @name={{t "modals.register-payment.notes-label"}}>
            <Textarea @value={{@options.form.notes}} class="form-input w-full" rows="2" placeholder={{t "modals.register-payment.notes-placeholder"}} />
        </InputGroup>

        <div class="mt-3 p-3 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-sm text-blue-700 dark:text-blue-300">
            {{t "modals.register-payment.auto-extend-info"}}
            {{#if (eq @options.form.billing_cycle "monthly")}}+1 mes{{/if}}
            {{#if (eq @options.form.billing_cycle "annual")}}+12 meses{{/if}}
            {{#if (eq @options.form.billing_cycle "custom")}}hasta la fecha indicada{{/if}}
        </div>

    </div>
</Modal::Default>
