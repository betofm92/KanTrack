<div class="landing-page min-h-screen bg-fleet-bg text-fleet-text-muted">
    {{page-title "Info | Fleet-Ops"}}

    <!-- Navbar -->
    <nav class="sticky top-0 z-50 bg-fleet-bg/90 backdrop-blur-sm border-b border-fleet-border">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-fleet-accent rounded-lg flex items-center justify-center">
                    <FaIcon @icon="truck" class="text-fleet-bg text-sm" />
                </div>
                <span class="text-white text-xl font-bold tracking-tight">Fleet-Ops</span>
            </div>

            <div class="hidden md:flex items-center space-x-10">
                <a href="#" class="nav-link text-sm uppercase tracking-wider font-semibold">Features</a>
                <a href="#" class="nav-link text-sm uppercase tracking-wider font-semibold">Pricing</a>
                <a href="#" class="nav-link text-sm uppercase tracking-wider font-semibold">About</a>
            </div>

            <div class="flex items-center space-x-4">
                <a href="/auth/login" class="btn-secondary text-sm">Login</a>
                <button type="button" class="btn-primary text-sm">Demo</button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
            <div class="inline-block px-3 py-1 bg-fleet-accent/10 border border-fleet-accent/20 rounded-full">
                <span class="text-[10px] uppercase tracking-widest font-bold text-fleet-accent">Logística
                    Inteligente</span>
            </div>
            <h1 class="text-6xl md:text-7xl font-extrabold tracking-tight">
                Gestión de flotas <span class="highlight">inteligente</span> y simplificada
            </h1>
            <p class="text-xl max-w-lg leading-relaxed font-normal">
                Optimiza tus operaciones, reduce costos y toma decisiones basadas en datos en tiempo real con nuestra
                plataforma todo-en-uno.
            </p>
            <div class="flex items-center space-x-4 pt-4">
                <button type="button" class="btn-primary text-sm uppercase tracking-wider">Comenzar ahora</button>
                <button type="button" class="btn-secondary text-sm uppercase tracking-wider">Ver demo</button>
            </div>
            <div class="flex items-center space-x-4 pt-8 grayscale opacity-50">
                <div class="text-sm font-bold uppercase tracking-widest">+500 empresas confían en nosotros</div>
            </div>
        </div>

        <div class="relative">
            <div class="absolute -inset-1 bg-fleet-accent/20 rounded-[24px] blur-2xl"></div>
            <div
                class="relative card border-fleet-border shadow-2xl overflow-hidden hover:scale-[1.02] transition-transform duration-500">
                <img src="/images/landing/preview.png" alt="Platform Preview"
                    class="w-full rounded-lg shadow-inner border border-white/5">
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-24 bg-fleet-bg">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-3 gap-8">
                <div class="card group hover:border-fleet-accent/50 transition-colors">
                    <div class="flex justify-between items-start mb-8">
                        <div
                            class="w-12 h-12 rounded-xl bg-fleet-accent/10 flex items-center justify-center text-fleet-accent">
                            <FaIcon @icon="gas-pump" @size="lg" />
                        </div>
                    </div>
                    <h3 class="text-2xl mb-2">Ahorro de Combustible</h3>
                    <p class="text-fleet-text-muted">Reducción promedio del 15% en costos operativos mediante
                        optimización de rutas.</p>
                </div>

                <div class="card group hover:border-fleet-accent/50 transition-colors">
                    <div class="flex justify-between items-start mb-8">
                        <div
                            class="w-12 h-12 rounded-xl bg-fleet-accent/10 flex items-center justify-center text-fleet-accent">
                            <FaIcon @icon="map-marked-alt" @size="lg" />
                        </div>
                    </div>
                    <h3 class="text-2xl mb-2">Seguimiento Real-Time</h3>
                    <p class="text-fleet-text-muted">Visibilidad completa de cada unidad con actualizaciones cada 10
                        segundos.</p>
                </div>

                <div class="card group hover:border-fleet-accent/50 transition-colors">
                    <div class="flex justify-between items-start mb-8">
                        <div
                            class="w-12 h-12 rounded-xl bg-fleet-accent/10 flex items-center justify-center text-fleet-accent">
                            <FaIcon @icon="calendar-check" @size="lg" />
                        </div>
                    </div>
                    <h3 class="text-2xl mb-2">Mantenimiento Preventivo</h3>
                    <p class="text-fleet-text-muted">Alertas automáticas para evitar paradas no programadas y extender
                        la vida útil.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 border-t border-fleet-border">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-20 space-y-4">
                <h2 class="text-4xl text-center">Soluciones para una operación eficiente</h2>
                <p class="text-fleet-text-muted text-center max-w-2xl mx-auto">Todo lo que necesitas para gestionar tu
                    flota desde una sola plataforma unificada.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-16">
                <div class="text-center space-y-4">
                    <FaIcon @icon="shield-alt" class="text-fleet-accent text-3xl mb-4" />
                    <h3 class="text-xl">Seguridad de Flota</h3>
                    <p class="text-sm">Monitoreo de comportamiento del conductor y alertas de incidentes.</p>
                </div>

                <div class="text-center space-y-4">
                    <FaIcon @icon="chart-line" class="text-fleet-accent text-3xl mb-4" />
                    <h3 class="text-xl">Analítica Avanzada</h3>
                    <p class="text-sm">Reportes detallados y KPIs personalizados para tu negocio.</p>
                </div>

                <div class="text-center space-y-4">
                    <FaIcon @icon="mobile-alt" class="text-fleet-accent text-3xl mb-4" />
                    <h3 class="text-xl">App para Conductores</h3>
                    <p class="text-sm">Herramientas intuitivas para la gestión de tareas y comunicación.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA Banner -->
    <section class="max-w-7xl mx-auto px-6 pb-24">
        <div
            class="bg-fleet-card border border-fleet-border p-16 md:p-24 rounded-[40px] text-center space-y-10 relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-fleet-accent/5 blur-3xl rounded-full"></div>
            <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-fleet-accent/5 blur-3xl rounded-full"></div>

            <h2 class="text-5xl md:text-6xl font-extrabold tracking-tighter max-w-3xl mx-auto text-white">
                ¿Listo para transformar tu operación?
            </h2>
            <p class="text-xl text-fleet-text-muted max-w-2xl mx-auto">
                Únete a cientos de empresas que ya están ahorrando tiempo y dinero con Fleet-Ops.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 pt-4">
                <button type="button" class="btn-primary px-12 py-5 text-sm uppercase tracking-widest">Comenzar
                    Gratis</button>
                <button type="button" class="btn-secondary px-12 py-5 text-sm uppercase tracking-widest">Hablar con un
                    experto</button>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer
        class="max-w-7xl mx-auto px-6 py-12 border-t border-fleet-border flex flex-col md:flex-row items-center justify-between gap-8 text-[10px] font-bold uppercase tracking-[0.2em] text-fleet-text-muted">
        <div class="flex items-center space-x-2">
            <div class="w-6 h-6 bg-fleet-accent rounded flex items-center justify-center">
                <FaIcon @icon="truck" class="text-fleet-bg text-[10px]" />
            </div>
            <span class="text-white">Fleet-Ops</span>
        </div>

        <nav class="flex space-x-12">
            <a href="#" class="hover:text-fleet-accent transition-colors">Términos</a>
            <a href="#" class="hover:text-fleet-accent transition-colors">Privacidad</a>
            <a href="#" class="hover:text-fleet-accent transition-colors">Cookies</a>
        </nav>

        <div>
            © 2024 Fleet-Ops Inc.
        </div>
    </footer>
</div>