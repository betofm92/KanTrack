# Normalize line endings to LF on checkout for all text files
* text=auto eol=lf

# Explicitly set LF for source files
*.js    text eol=lf
*.ts    text eol=lf
*.hbs   text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.less  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.php   text eol=lf
*.sh    text eol=lf

# Binary files - no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.pack  binary
*.idx   binary
